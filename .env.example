GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=www-infinity
GITHUB_REPO=Open-Flaw
PORT=3000

# AI LLM proxy — kept server-side so your API key is never exposed to the browser
# Works with OpenAI, OpenRouter, Groq, or any OpenAI-compatible endpoint
AI_API_KEY=your_ai_api_key_here
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo
